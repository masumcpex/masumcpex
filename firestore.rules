rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // khData/members এবং khData/records — সবাই পড়তে পারবে (পাবলিক ভিউ),
    // কিন্তু লেখা/এডিট শুধু masumcpex@gmail.com দিয়ে লগইন করা এডমিনই পারবে।
    match /khData/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "masumcpex@gmail.com";
    }

    // বাকি সব কিছুর জন্য ডিফল্টভাবে সব বন্ধ (নিরাপত্তার জন্য)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
